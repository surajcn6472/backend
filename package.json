{
  "name": "backend",
  "version": "1.0.0",
  "description": "Express + Handlebars + Tailwind CSS",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "concurrently \"npm run watch:css\" \"npm run dev\"",
    "dev": "nodemon app.js",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "watch:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
    "production": "npm run build:css && node app.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-handlebars": "^8.0.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "mongoose": "^9.1.5",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19"
  }
}
